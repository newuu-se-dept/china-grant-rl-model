# =============================================================================
# NeTrainSim .gitignore — C++ / Qt6 / CMake project
# =============================================================================

# -----------------------------------------------------------------------------
# Build directories
# -----------------------------------------------------------------------------
build/
build-*/
cmake-build-*/

# -----------------------------------------------------------------------------
# CMake generated files
# -----------------------------------------------------------------------------
CMakeCache.txt
CMakeFiles/
CMakeScripts/
cmake_install.cmake
install_manifest.txt
CTestTestfile.cmake
_deps/

# -----------------------------------------------------------------------------
# Compiled object files & libraries
# -----------------------------------------------------------------------------
*.o
*.obj
*.a
*.lib
*.so
*.so.*
*.dylib
*.dll
*.prl

# -----------------------------------------------------------------------------
# Executables (stray root-level binaries)
# -----------------------------------------------------------------------------
*.exe
*.app
/NeTrainSim
/NeTrainSimConsole
/NeTrainSimServer

# -----------------------------------------------------------------------------
# Qt generated / MOC files
# -----------------------------------------------------------------------------
moc_*.cpp
moc_*.h
ui_*.h
qrc_*.cpp
*.moc
*_pch.h.cpp
*_resource.rc
*_autogen/
*.qm

# -----------------------------------------------------------------------------
# Qt Creator / qmake
# -----------------------------------------------------------------------------
*.pro.user*
CMakeLists.txt.user*
/.qmake.cache
/.qmake.stash
*.autosave

# -----------------------------------------------------------------------------
# Logs & runtime output
# -----------------------------------------------------------------------------
*.log
log.txt
/res/
/output/

# -----------------------------------------------------------------------------
# macOS
# -----------------------------------------------------------------------------
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes
.directory

# -----------------------------------------------------------------------------
# Windows
# -----------------------------------------------------------------------------
Thumbs.db
Desktop.ini

# -----------------------------------------------------------------------------
# Visual Studio / MSVC
# -----------------------------------------------------------------------------
/.vs/
*.sln
*.suo
*.vcxproj
*vcxproj.*
*.vcproj
*vcproj.*.*.user
*.ncb
*.sdf
*.opensdf
*.idb
*.ilk
*.pdb
*.res
*.rc
*.ib_pdb_index
*.Debug
*.Release

# -----------------------------------------------------------------------------
# VS Code
# -----------------------------------------------------------------------------
.vscode/

# -----------------------------------------------------------------------------
# CLion / JetBrains
# -----------------------------------------------------------------------------
.idea/
*.iml

# -----------------------------------------------------------------------------
# Qt Creator clangd cache
# -----------------------------------------------------------------------------
.qtc_clangd/
**/.qtc_clangd/

# -----------------------------------------------------------------------------
# Vim / Emacs / xemacs
# -----------------------------------------------------------------------------
*.swp
*.swo
.*.swp
*~
.#*
*.*#
*.flc
*.orig
*.rej
*.debug

# -----------------------------------------------------------------------------
# Python (tooling / scripts)
# -----------------------------------------------------------------------------
*.py
*.pyc
*.pyo
__pycache__/

# -----------------------------------------------------------------------------
# Installer packages (generated data only)
# -----------------------------------------------------------------------------
/src/NeTrainSimInstaller/packages/com.VTTICSM.NeTrainSim/data/
/src/NeTrainSimInstaller/packages/com.VTTICSM.NeTrainSimGUI/data/

# -----------------------------------------------------------------------------
# Misc
